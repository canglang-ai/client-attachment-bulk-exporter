{
  "manifest_version": 3,
  "name": "批量导出附件（MokaHR PDF）",
  "version": "0.1.0",
  "description": "导入申请ID表格，自动打开详情页并下载PDF附件，统一保存到同一文件夹。",
  "action": {
    "default_title": "批量导出附件",
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "tabs", "downloads", "scripting"],
  "host_permissions": ["https://app.mokahr.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://app.mokahr.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

